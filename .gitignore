```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
vendor/
node_modules/

# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Backup files
*~
*.bak
*.backup

# Cache directories
.cache/
*.cache

# Distribution / Build artifacts
dist/
build/
target/
*.so
*.dll
*.dylib
*.exe

# Compression archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```